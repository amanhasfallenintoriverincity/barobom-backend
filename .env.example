# Barobom Backend Environment
# Copy to .env and fill in values

# Database (SQLite for local dev, PostgreSQL for production)
# DATABASE_URL=sqlite:///./barobom.db

# Langfuse (optional)
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

# Gemini
# GEMINI_API_KEY=

# Server
HOST=0.0.0.0
PORT=8000
